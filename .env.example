# Backend production environment
# Required
NODE_ENV=production
PORT=5000
MONGODB_URI=<mongodb-connection-string>
CHAIN_ID=80002

# RPC providers. At least one HTTP and one WS URL are required.
RPC_URL_1=https://YOUR_HTTP_RPC_PRIMARY
RPC_URL_2=https://YOUR_HTTP_RPC_SECONDARY
RPC_URL_3=https://YOUR_HTTP_RPC_TERTIARY
WS_RPC_URL_1=wss://YOUR_WS_RPC_PRIMARY
WS_RPC_URL_2=wss://YOUR_WS_RPC_SECONDARY
WS_RPC_URL_3=wss://YOUR_WS_RPC_TERTIARY

# Deployed contracts. Required unless marked optional.
USDT_ADDRESS=0x0000000000000000000000000000000000000000
ESCROW_ADDRESS=0x0000000000000000000000000000000000000000
REGISTRATION_ADDRESS=0x0000000000000000000000000000000000000000
LEVEL_MANAGER_ADDRESS=0x0000000000000000000000000000000000000000
P4_ORBIT_ADDRESS=0x0000000000000000000000000000000000000000
P12_ORBIT_ADDRESS=0x0000000000000000000000000000000000000000
P39_ORBIT_ADDRESS=0x0000000000000000000000000000000000000000
FGT_TOKEN_ADDRESS=
FGTR_TOKEN_ADDRESS=
FREEDOM_TOKEN_CONTROLLER_ADDRESS=
MULTISIG_ADDRESS=
GUARDIAN_ADDRESS=

# Indexer start blocks. Use deployment block minus a small safety margin.
START_BLOCK=0
START_BLOCK_REGISTRATION=0
START_BLOCK_LEVEL_MANAGER=0
START_BLOCK_ESCROW=0
START_BLOCK_AUTO_UPGRADE_ESCROW=0
START_BLOCK_P4_ORBIT=0
START_BLOCK_P12_ORBIT=0
START_BLOCK_P39_ORBIT=0
START_BLOCK_FGT_TOKEN=0
START_BLOCK_FGTR_TOKEN=0
RUN_INDEXER=false
SYNC_CONFIRMATIONS=2
SYNC_BLOCK_CHUNK_SIZE=5
SYNC_POLL_INTERVAL_MS=15000
INDEXER_LEASE_TTL_MS=120000
INDEXER_LEASE_RENEW_MS=30000
INDEXER_REPLAY_CHUNK_SIZE=100
INDEXER_LIVE_TAIL_ENABLED=true
INDEXER_LIVE_TAIL_WINDOW_BLOCKS=12
INDEXER_LIVE_TAIL_EVERY_N_PASSES=120
INDEXER_LIVE_TAIL_MAX_CHUNK_SIZE=12
INDEXER_INTER_TARGET_DELAY_MS=25
INDEXER_IMMEDIATE_PASS_DEBOUNCE_MS=10000

# Database and RPC tuning.
DB_AUTO_INDEX=false
DB_MAX_POOL_SIZE=10
DB_SERVER_SELECTION_TIMEOUT_MS=15000
DB_SOCKET_TIMEOUT_MS=45000
RPC_MAX_CONCURRENCY=4
RPC_MAX_RPS=50
RPC_RETRY_ATTEMPTS=5
RPC_RETRY_BASE_DELAY_MS=1200
RPC_OUT_OF_CREDITS_COOLDOWN_MS=60000
RPC_RATE_LIMIT_COOLDOWN_MS=15000
RPC_TRANSIENT_COOLDOWN_MS=6000
WS_RECONNECT_BASE_DELAY_MS=2000
WS_RECONNECT_MAX_DELAY_MS=30000
WS_FALLBACK_POLL_INTERVAL_MS=4000

# Security and CORS.
ADMIN_API_KEY=<rotated-high-entropy-admin-key>
ADMIN_API_HEADER=x-admin-key
FRONTEND_ORIGIN=https://YOUR_FRONTEND_DOMAIN
CORS_ALLOWED_ORIGINS=https://YOUR_FRONTEND_DOMAIN
REFERRAL_BASE_URL=https://YOUR_FRONTEND_DOMAIN/ref

# Notifications and Telegram.
NOTIFICATIONS_ENABLED=true
NOTIFICATION_RETENTION_DAYS=90
NOTIFICATION_DELIVERY_RETRY_LIMIT=5
NOTIFICATION_DELIVERY_RETRY_BASE_DELAY_MS=30000
NOTIFICATION_DIGEST_ENABLED=false
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=<telegram-bot-token>
TELEGRAM_BOT_USERNAME=<telegram-bot-username-without-at>
TELEGRAM_WEBHOOK_SECRET=<telegram-webhook-secret>
TELEGRAM_WEBHOOK_URL=https://YOUR_BACKEND_DOMAIN/api/telegram/webhook
TELEGRAM_ADMIN_CHAT_ID=<telegram-admin-chat-id>
TELEGRAM_USER_NOTIFICATIONS_ENABLED=false
TELEGRAM_ADMIN_REPORTS_ENABLED=false

# Optional monitoring.
SENTRY_DSN=
LOG_LEVEL=info
